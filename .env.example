# ───────────────────────── Kreader 环境变量 ─────────────────────────
# 复制为 .env 后填入你自己的值。.env 已被 .gitignore 忽略，不会提交。

# 数据库（默认 SQLite，开箱即用；换 Postgres 时把 provider 改成 postgresql 即可）
DATABASE_URL="file:./dev.db"

# ── AI 模型 · 通义千问 QWEN（DashScope OpenAI 兼容模式）────────────────
# 控制台：https://dashscope.console.aliyun.com/
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"

# ── AI 模型 · DeepSeek ───────────────────────────────────────────────
# 控制台：https://platform.deepseek.com/
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# 各功能默认使用哪个 provider（可在设置界面覆盖）
AI_PROVIDER_TRANSLATE="qwen"
AI_PROVIDER_QA="deepseek"
AI_PROVIDER_RECAP="deepseek"
